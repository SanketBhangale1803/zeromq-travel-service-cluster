        "path": "follower2_log.db"
      }
    },
    "3": {
      "role": "follower",
      "network": {
        "heartbeat_address": "tcp://localhost:5555",
        "control_address": "tcp://localhost:5560",
        "election_address": "tcp://localhost:5563"
      },
      "database": {
        "path": "follower3_log.db"
      }
